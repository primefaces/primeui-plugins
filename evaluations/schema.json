{
  "$defs": {
    "call": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string"
        },
        "name": {
          "enum": [
            "list",
            "search",
            "get_component",
            "get_guide",
            "get_example",
            "get_setup",
            "validate_usage",
            "version"
          ]
        },
        "result": {
          "minLength": 1,
          "type": "string"
        },
        "server": {
          "enum": [
            "primevue",
            "primeng",
            "primereact"
          ]
        }
      },
      "required": [
        "name",
        "result",
        "server"
      ],
      "type": "object"
    },
    "scenario": {
      "additionalProperties": false,
      "properties": {
        "allowedMcpCalls": {
          "items": {
            "type": "string"
          },
          "type": "array",
          "uniqueItems": true
        },
        "ambiguityExpectation": {
          "type": "string"
        },
        "budgetClass": {
          "minLength": 1,
          "type": "string"
        },
        "coverage": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "doctorExpectation": {
          "additionalProperties": false,
          "properties": {
            "command": {
              "type": "string"
            },
            "required": {
              "const": true
            }
          },
          "required": [
            "command",
            "required"
          ],
          "type": "object"
        },
        "environment": {
          "type": "string"
        },
        "expectedSkill": {
          "pattern": "^[a-z][a-z0-9-]+$",
          "type": "string"
        },
        "expectedValidation": {
          "additionalProperties": false,
          "properties": {
            "calls": {
              "minimum": 0,
              "type": "integer"
            },
            "outcome": {
              "enum": [
                "ambiguous",
                "issue-then-pass",
                "not-run",
                "pass",
                "unsupported"
              ]
            },
            "repeatOnlyAfterIssue": {
              "type": "boolean"
            }
          },
          "required": [
            "calls",
            "outcome",
            "repeatOnlyAfterIssue"
          ],
          "type": "object"
        },
        "forbiddenMcpCalls": {
          "items": {
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "id": {
          "pattern": "^(primevue|primeng|primereact)-[a-z0-9]+(?:-[a-z0-9]+)*$",
          "type": "string"
        },
        "library": {
          "enum": [
            "primevue",
            "primeng",
            "primereact"
          ]
        },
        "maxCallCount": {
          "minimum": 0,
          "type": "integer"
        },
        "mode": {
          "type": [
            "string",
            "null"
          ]
        },
        "modeExpectation": {
          "type": "string"
        },
        "prompt": {
          "minLength": 20,
          "type": "string"
        },
        "requiredEvidence": {
          "items": {
            "minLength": 1,
            "type": "string"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "route": {
          "enum": [
            "accessibility",
            "audit",
            "component",
            "migration",
            "setup",
            "theming"
          ]
        },
        "trace": {
          "items": {
            "$ref": "#/$defs/call"
          },
          "type": "array"
        }
      },
      "required": [
        "allowedMcpCalls",
        "budgetClass",
        "coverage",
        "expectedSkill",
        "expectedValidation",
        "forbiddenMcpCalls",
        "id",
        "library",
        "maxCallCount",
        "prompt",
        "requiredEvidence",
        "route",
        "trace"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "const": "./schema.json"
    },
    "library": {
      "enum": [
        "primevue",
        "primeng",
        "primereact"
      ]
    },
    "mcp": {
      "additionalProperties": false,
      "properties": {
        "package": {
          "type": "string"
        },
        "server": {
          "enum": [
            "primevue",
            "primeng",
            "primereact"
          ]
        },
        "tools": {
          "items": {
            "type": "string"
          },
          "maxItems": 8,
          "minItems": 8,
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "package",
        "server",
        "tools"
      ],
      "type": "object"
    },
    "scenarios": {
      "items": {
        "$ref": "#/$defs/scenario"
      },
      "minItems": 10,
      "type": "array"
    },
    "schemaVersion": {
      "const": 1
    }
  },
  "required": [
    "$schema",
    "library",
    "mcp",
    "scenarios",
    "schemaVersion"
  ],
  "type": "object"
}
