{
  "$defs": {
    "exactSemver": {
      "pattern": "^(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)\\.(0|[1-9][0-9]*)(?:-(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*)(?:\\.(?:0|[1-9][0-9]*|[0-9]*[A-Za-z-][0-9A-Za-z-]*))*)?(?:\\+[0-9A-Za-z-]+(?:\\.[0-9A-Za-z-]+)*)?$",
      "type": "string"
    },
    "lock": {
      "additionalProperties": false,
      "properties": {
        "lockState": {
          "enum": [
            "locked",
            "unresolved"
          ],
          "type": "string"
        },
        "name": {
          "enum": [
            "primevue",
            "primeng",
            "primereact"
          ],
          "type": "string"
        },
        "pluginVersion": {
          "$ref": "#/$defs/exactSemver"
        },
        "skills": {
          "items": {
            "$ref": "#/$defs/skillLock"
          },
          "minItems": 1,
          "type": "array"
        },
        "unresolvedReason": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "lockState",
        "name",
        "pluginVersion",
        "skills"
      ],
      "type": "object"
    },
    "primengLock": {
      "allOf": [
        {
          "$ref": "#/$defs/lock"
        },
        {
          "properties": {
            "name": {
              "const": "primeng"
            }
          }
        }
      ]
    },
    "primereactLock": {
      "allOf": [
        {
          "$ref": "#/$defs/lock"
        },
        {
          "properties": {
            "name": {
              "const": "primereact"
            }
          }
        }
      ]
    },
    "primevueLock": {
      "allOf": [
        {
          "$ref": "#/$defs/lock"
        },
        {
          "properties": {
            "name": {
              "const": "primevue"
            }
          }
        }
      ]
    },
    "relativePath": {
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.?(?:/|$))[A-Za-z0-9._@/-]+$",
      "type": "string"
    },
    "repository": {
      "const": "https://github.com/primefaces/primeui-plugins",
      "type": "string"
    },
    "skillLock": {
      "additionalProperties": false,
      "properties": {
        "directory": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "id": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "name": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "type": "string"
        },
        "order": {
          "minimum": 0,
          "type": "integer"
        },
        "owner": {
          "enum": [
            "primevue",
            "primeng",
            "primereact"
          ],
          "type": "string"
        },
        "source": {
          "$ref": "#/$defs/source"
        }
      },
      "required": [
        "directory",
        "id",
        "name",
        "order",
        "owner",
        "source"
      ],
      "type": "object"
    },
    "source": {
      "additionalProperties": false,
      "properties": {
        "path": {
          "$ref": "#/$defs/relativePath"
        },
        "repository": {
          "$ref": "#/$defs/repository"
        },
        "treeHash": {
          "anyOf": [
            {
              "pattern": "^sha256:[0-9a-f]{64}$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "path",
        "repository",
        "treeHash"
      ],
      "type": "object"
    }
  },
  "$id": "https://primefaces.org/schemas/primeui-plugins/sources-lock.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "const": "./schemas/sources-lock.schema.json"
    },
    "schemaVersion": {
      "const": 4
    },
    "sources": {
      "items": false,
      "maxItems": 3,
      "minItems": 3,
      "prefixItems": [
        {
          "$ref": "#/$defs/primevueLock"
        },
        {
          "$ref": "#/$defs/primengLock"
        },
        {
          "$ref": "#/$defs/primereactLock"
        }
      ],
      "type": "array"
    }
  },
  "required": [
    "$schema",
    "schemaVersion",
    "sources"
  ],
  "title": "PrimeUI plugin source lock",
  "type": "object"
}
